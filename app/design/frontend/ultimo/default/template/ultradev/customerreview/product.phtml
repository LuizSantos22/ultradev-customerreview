<script>
(function () {
    var total = 251.327;
    document.querySelectorAll('#ultradev-customerreview .cr-progress').forEach(function (path) {
        var pct    = parseFloat(path.getAttribute('data-percent')) || 0;
        var offset = total - (total * pct / 100);
        path.style.setProperty('--cr-offset', offset);
    });

    var btn     = document.getElementById('crBtnAvaliar');
    var overlay = document.getElementById('crModalOverlay');
    var close   = document.getElementById('crModalClose');

    if (!btn || !overlay) return;

    btn.addEventListener('click', function () {
        overlay.classList.add('cr-modal--open');
        document.body.style.overflow = 'hidden';
    });

    function closeModal() {
        overlay.classList.remove('cr-modal--open');
        document.body.style.overflow = '';
    }

    close.addEventListener('click', closeModal);
    overlay.addEventListener('click', function (e) {
        if (e.target === overlay) closeModal();
    });
    document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') closeModal();
    });

    var visibleRow = document.querySelector('#ultradev-customerreview .cr-modal-rating-row:not(.cr-rating-hidden)');
    if (visibleRow) {
        visibleRow.querySelectorAll('.cr-star-input').forEach(function (input) {
            input.addEventListener('change', function () {
                var selectedValue = parseInt(this.getAttribute('data-value'));
                document.querySelectorAll('#ultradev-customerreview .cr-rating-hidden .cr-star-input').forEach(function (hiddenInput) {
                    if (parseInt(hiddenInput.getAttribute('data-value')) === selectedValue) {
                        hiddenInput.checked = true;
                    }
                });
            });
        });
    }
})();
</script>